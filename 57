public async Task<Parametros> GetByCode(string clave)
{
    try
    {
        using var reader = await _dbHelper.ExecuteReaderAsync(
            "getParametroByClave",
            new Dictionary<string, object>
            {
                { "@Clave", clave }
            });

        if (await reader.ReadAsync())
        {
            return new Parametros
            {
                clave = reader.GetString(0),
                valor = reader.GetString(1)
            };
        }

        return new Parametros();
    }
    catch (Exception ex)
    {
        _logger.LogError(ex,
            "Error consultando parámetro con clave {Clave}",
            clave);

        throw;
    }
}