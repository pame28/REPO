using Criptografia.Models;
using Criptografia.Repositories.Interfaces;
using Microsoft.Extensions.Logging;
using System.Data.Odbc;

namespace Criptografia.Repositories
{
    public class AccessTokenRepository : IAccessTokenRepository
    {
        private readonly IConfiguration _configuration;
        private readonly ILogger<AccessTokenRepository> _logger;

        public AccessTokenRepository(IConfiguration configuration, ILogger<AccessTokenRepository> logger)
        {
            _configuration = configuration;
            _logger = logger;
        }

        public async Task<AccessTokenModel> GetTokenAsync()
        {
            try
            {
                _logger.LogInformation("Iniciando consulta de credenciales en AS400.");

                var connectionString = _configuration.GetConnectionString("AS400Connection");

                if (string.IsNullOrEmpty(connectionString))
                {
                    _logger.LogError("La cadena de conexión AS400Connection no está configurada.");
                    throw new Exception("Error de configuración de conexión.");
                }

                using var connection = new OdbcConnection(connectionString);
                await connection.OpenAsync();

                _logger.LogInformation("Conexión a AS400 establecida correctamente.");

                string query = @"
                    SELECT 
                        APICLIENID AS CLIENTID,
                        APISECREID AS SECRETID
                    FROM TCATV3DAT.TCACCTOK
                    WHERE APISERVICE = 'SERVWEB'
                    FETCH FIRST 1 ROW ONLY";

                using var command = new OdbcCommand(query, connection);

                using var reader = await command.ExecuteReaderAsync();

                if (await reader.ReadAsync())
                {
                    _logger.LogInformation("Credenciales obtenidas correctamente desde AS400.");

                    return new AccessTokenModel
                    {
                        ClientId = reader["CLIENTID"].ToString()!.Trim(),
                        SecretId = reader["SECRETID"].ToString()!.Trim()
                    };
                }

                _logger.LogWarning("No se encontraron credenciales para el servicio SERVWEB.");

                throw new Exception("Credenciales no encontradas en AS400");
            }
            catch (OdbcException ex)
            {
                _logger.LogError(ex, "Error de ODBC al consultar AS400.");
                throw;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error general al obtener credenciales desde AS400.");
                throw;
            }
        }
    }
}














using Criptografia.Repositories.Interfaces;
using Criptografia.Services.Interfaces;
using Microsoft.Extensions.Logging;
using System.Security.Cryptography;
using System.Text;

namespace Criptografia.Services
{
    public class AccessTokenService : IAccessTokenService
    {
        private readonly IAccessTokenRepository _repository;
        private readonly IConfiguration _configuration;
        private readonly ILogger<AccessTokenService> _logger;

        public AccessTokenService(
            IAccessTokenRepository repository,
            IConfiguration configuration,
            ILogger<AccessTokenService> logger)
        {
            _repository = repository;
            _configuration = configuration;
            _logger = logger;
        }

        public async Task<string> GenerateAuthorizationAsync()
        {
            try
            {
                _logger.LogInformation("Iniciando generación de token de autorización.");

                var token = await _repository.GetTokenAsync();

                string credentials = $"{token.ClientId}:{token.SecretId}";

                _logger.LogInformation("Credenciales obtenidas, procediendo a convertir a Base64.");

                string base64Credentials = Convert.ToBase64String(
                    Encoding.UTF8.GetBytes(credentials)
                );

                string secretKey = _configuration["Security:SecretKey"]!;

                if (string.IsNullOrEmpty(secretKey))
                {
                    _logger.LogError("La clave Security:SecretKey no está configurada.");
                    throw new Exception("Clave de seguridad no configurada.");
                }

                _logger.LogInformation("Procediendo a encriptar las credenciales con AES256.");

                string encrypted = AES256Utils.Encrypt(base64Credentials, secretKey);

                _logger.LogInformation("Token generado correctamente.");

                return $"Basic {encrypted}";
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error generando el token de autorización.");
                throw;
            }
        }

        public static class AES256Utils
        {
            private const int IV_SIZE = 12;
            private const int TAG_SIZE = 16;

            public static string Encrypt(string plainText, string secretKey)
            {
                byte[] iv = RandomNumberGenerator.GetBytes(IV_SIZE);

                byte[] key = SHA256.HashData(Encoding.UTF8.GetBytes(secretKey));

                byte[] plaintextBytes = Encoding.UTF8.GetBytes(plainText);

                byte[] cipherText = new byte[plaintextBytes.Length];
                byte[] tag = new byte[TAG_SIZE];

                using var aes = new AesGcm(key);

                aes.Encrypt(iv, plaintextBytes, cipherText, tag);

                byte[] result = new byte[iv.Length + cipherText.Length + tag.Length];

                Buffer.BlockCopy(iv, 0, result, 0, iv.Length);
                Buffer.BlockCopy(cipherText, 0, result, iv.Length, cipherText.Length);
                Buffer.BlockCopy(tag, 0, result, iv.Length + cipherText.Length, tag.Length);

                return Convert.ToBase64String(result);
            }
        }
    }
}













using Criptografia.Services.Interfaces;
using Microsoft.AspNetCore.Mvc;

namespace Criptografia.Controllers
{
    [ApiController]
    [Route("api/auth")]
    public class AuthController : ControllerBase
    {
        private readonly IAccessTokenService _tokenService;
        private readonly ILogger<AuthController> _logger;

        public AuthController(
            IAccessTokenService tokenService,
            ILogger<AuthController> logger)
        {
            _tokenService = tokenService;
            _logger = logger;
        }

        [HttpGet("token")]
        public async Task<IActionResult> GetToken()
        {
            try
            {
                _logger.LogInformation("Solicitud recibida para generación de token.");

                var token = await _tokenService.GenerateAuthorizationAsync();

                _logger.LogInformation("Token generado correctamente.");

                return Ok(new
                {
                    Authorization = token
                });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error en endpoint /api/auth/token");

                return StatusCode(500, new
                {
                    message = "Ocurrió un error al generar el token."
                });
            }
        }
    }
}