using System.Reflection;

var assembly = Assembly.GetExecutingAssembly();

var logoStream = assembly.GetManifestResourceStream("reposicion_pin.Assets.logoBanpais.png");
var logo = new LinkedResource(logoStream!, MediaTypeNames.Image.Png)
{
    ContentId = "logoBanpais",
    TransferEncoding = TransferEncoding.Base64
};











var footerStream = assembly.GetManifestResourceStream("reposicion_pin.Assets.footerBanpais.png");
var footer = new LinkedResource(footerStream!, MediaTypeNames.Image.Png)
{
    ContentId = "footerBanpais",
    TransferEncoding = TransferEncoding.Base64
};
