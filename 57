using transacciones_flotantes.DTOs.Response;
using transacciones_flotantes.Service.Interface;

namespace transacciones_flotantes.Utils
{
    public class GeneralResponseFn
    {
        private readonly IValidationService _validationService;

        public GeneralResponseFn(IValidationService validationService)
        {
            _validationService = validationService;
        }

        // Para respuestas exitosas
        public async Task<GeneralResponse> ResponseSuccess(int status, string code, object? data)
        {
            return new GeneralResponse
            {
                Status = status,
                HasError = false,
                Data = data,
                Messages = new List<Messages>
                {
                    new Messages
                    {
                        Code = code,
                        Description = await _validationService.getMensajeValidacion(code)
                    }
                }
            };
        }

        // Para respuestas de error
        public static GeneralResponse ResponseError(int status, string description)
        {
            return new GeneralResponse
            {
                Status = status,
                HasError = true,
                Data = null,
                Messages = new List<Messages>
                {
                    new Messages
                    {
                        Code = Constantes.CODE_SYSTEM_ERROR,
                        Description = description
                    }
                }
            };
        }
    }
}