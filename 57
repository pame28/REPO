using Microsoft.Data.SqlClient;
using System.Data;

namespace transacciones_flotantes.Infrastructure.Data
{
    public class DBHelper
    {
        private readonly string _connectionString;
        private readonly ILogger<DBHelper> _logger;

        public DBHelper(IConfiguration configuration, ILogger<DBHelper> logger)
        {
            _connectionString = configuration
                .GetConnectionString("TransaccionesFlotantesConnection")!;

            _logger = logger;
        }

        #region Métodos Públicos

        // Ejecutar un stored procedure que devuelve un SqlDataReader
        public async Task<SqlDataReader> ExecuteReaderAsync(
            string storedProcedure,
            Dictionary<string, object>? parameters = null)
        {
            try
            {
                var conn = new SqlConnection(_connectionString);
                await conn.OpenAsync();

                var cmd = new SqlCommand(storedProcedure, conn)
                {
                    CommandType = CommandType.StoredProcedure
                };

                AddParameters(cmd, parameters);

                return await cmd.ExecuteReaderAsync(CommandBehavior.CloseConnection);
            }
            catch (SqlException ex)
            {
                _logger.LogError(ex,
                    "Error ejecutando ExecuteReaderAsync para StoredProcedure {StoredProcedure}",
                    storedProcedure);

                throw; // Mantiene el tipo original y el stack trace
            }
        }

        // Ejecutar INSERT, UPDATE, DELETE
        public async Task<int> ExecuteNonQueryAsync(
            string storedProcedure,
            Dictionary<string, object>? parameters = null)
        {
            try
            {
                if (_logger.IsEnabled(LogLevel.Information))
                {
                    _logger.LogInformation(
                        "Iniciando ExecuteNonQueryAsync - StoredProcedure {StoredProcedure}",
                        storedProcedure);
                }

                await using var conn = new SqlConnection(_connectionString);
                await conn.OpenAsync();

                await using var cmd = new SqlCommand(storedProcedure, conn)
                {
                    CommandType = CommandType.StoredProcedure
                };

                AddParameters(cmd, parameters);

                var result = await cmd.ExecuteNonQueryAsync();

                if (_logger.IsEnabled(LogLevel.Information))
                {
                    _logger.LogInformation(
                        "StoredProcedure {StoredProcedure} ejecutado exitosamente",
                        storedProcedure);
                }

                return result;
            }
            catch (SqlException ex)
            {
                _logger.LogError(ex,
                    "Error ejecutando ExecuteNonQueryAsync para StoredProcedure {StoredProcedure}",
                    storedProcedure);

                throw;
            }
        }

        // Ejecutar un stored procedure escalar (ej: COUNT(*))
        public async Task<int> ExecuteScalarAsync(
            string storedProcedure,
            Dictionary<string, object>? parameters = null)
        {
            try
            {
                await using var conn = new SqlConnection(_connectionString);
                await conn.OpenAsync();

                await using var cmd = new SqlCommand(storedProcedure, conn)
                {
                    CommandType = CommandType.StoredProcedure
                };

                AddParameters(cmd, parameters);

                var result = await cmd.ExecuteScalarAsync();

                return Convert.ToInt32(result ?? 0);
            }
            catch (SqlException ex)
            {
                _logger.LogError(ex,
                    "Error ejecutando ExecuteScalarAsync para StoredProcedure {StoredProcedure}",
                    storedProcedure);

                throw;
            }
        }

        // Ejecutar query SQL directo (texto)
        public async Task<object?> ExecuteScalarSqlAsync(string sql)
        {
            try
            {
                await using var conn = new SqlConnection(_connectionString);
                await conn.OpenAsync();

                await using var cmd = new SqlCommand(sql, conn)
                {
                    CommandType = CommandType.Text
                };

                return await cmd.ExecuteScalarAsync();
            }
            catch (SqlException ex)
            {
                _logger.LogError(ex,
                    "Error ejecutando ExecuteScalarSqlAsync");

                throw;
            }
        }

        #endregion

        #region Métodos Privados

        private static void AddParameters(
            SqlCommand cmd,
            Dictionary<string, object>? parameters)
        {
            if (parameters == null)
                return;

            foreach (var param in parameters)
            {
                cmd.Parameters.AddWithValue(
                    param.Key,
                    param.Value ?? DBNull.Value);
            }
        }

        #endregion
    }
}