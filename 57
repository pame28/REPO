using Microsoft.Extensions.Caching.Memory;
using System.Net.Http.Headers;
using System.Text.Json;

public class ProveedorTokenService : IProveedorTokenService
{
    private readonly IHttpClientFactory _httpClientFactory;
    private readonly IMemoryCache _cache;
    private readonly IConfiguration _configuration;
    private readonly ILogger<ProveedorTokenService> _logger;

    private static readonly SemaphoreSlim _lock = new(1,1);

    private const string CACHE_TOKEN = "ACCESS_TOKEN";
    private const string CACHE_KEY = "BYTE_KEY";

    public ProveedorTokenService(
        IHttpClientFactory httpClientFactory,
        IMemoryCache cache,
        IConfiguration configuration,
        ILogger<ProveedorTokenService> logger)
    {
        _httpClientFactory = httpClientFactory;
        _cache = cache;
        _configuration = configuration;
        _logger = logger;
    }

    public async Task<string> ObtenerAccessTokenAsync()
    {
        if (_cache.TryGetValue(CACHE_TOKEN, out string token))
        {
            return token;
        }

        await _lock.WaitAsync();

        try
        {
            // Double check para evitar race conditions
            if (_cache.TryGetValue(CACHE_TOKEN, out token))
            {
                return token;
            }

            _logger.LogInformation("Generando nuevo accessToken...");

            var key = await ObtenerKeyAsync();

            var tokenResponse = await GenerarTokenAsync(key);

            var expiration = DateTime.UtcNow.AddSeconds(tokenResponse.expiresIn - 60);

            _cache.Set(
                CACHE_TOKEN,
                tokenResponse.accessToken,
                expiration
            );

            _logger.LogInformation("AccessToken generado y almacenado en cache");

            return tokenResponse.accessToken;
        }
        finally
        {
            _lock.Release();
        }
    }

    private async Task<string> ObtenerKeyAsync()
    {
        if (_cache.TryGetValue(CACHE_KEY, out string key))
        {
            return key;
        }

        _logger.LogInformation("Generando nuevo ByteKey...");

        var client = _httpClientFactory.CreateClient();

        var url = $"{_configuration["ApiSettings:BaseAddressByteKey"]}{_configuration["ApiSettings:EndpointByteKey"]}";

        var response = await client.GetAsync(url);

        response.EnsureSuccessStatusCode();

        var json = await response.Content.ReadAsStringAsync();

        var data = JsonSerializer.Deserialize<Dictionary<string,string>>(json);

        key = data["authorization"];

        _cache.Set(
            CACHE_KEY,
            key,
            TimeSpan.FromHours(24)
        );

        _logger.LogInformation("ByteKey almacenado en cache");

        return key;
    }

    private async Task<AccessTokenResponse> GenerarTokenAsync(string key)
    {
        var client = _httpClientFactory.CreateClient();

        var url = $"{_configuration["ApiSettings:BaseAddressAccessToken"]}{_configuration["ApiSettings:EndpointAccessToken"]}";

        var request = new HttpRequestMessage(HttpMethod.Get, url);

        request.Headers.Authorization =
            new AuthenticationHeaderValue("Basic", key.Replace("Basic ", ""));

        var response = await client.SendAsync(request);

        response.EnsureSuccessStatusCode();

        var json = await response.Content.ReadAsStringAsync();

        return JsonSerializer.Deserialize<AccessTokenResponse>(json);
    }
}