apiVersion: observability.openshift.io/v1
kind: ClusterLogForwarder
metadata:
  name: forward-des-procesadortc-bp
  namespace: des-procesadortc-bp
spec:
  serviceAccount:
    name: logcollector

  filters:
    - name: detect-java-multiline
      type: detectMultilineException

  inputs:
    - name: application-logs
      type: application
      application:
        includes:
          - namespace: des-procesadortc-bp

  outputs:
    - name: syslog-api-procesador
      type: syslog
      syslog:
        url: udp://10.100.***.**:514
        rfc: RFC5424
        facility: local3
        severity: informational
        enrichment: KubernetesMinimal
        appName: "api-procesador"   # valor fijo, no usa expression

    # Si tienes otra app:
    - name: syslog-worker-procesador
      type: syslog
      syslog:
        url: udp://10.100.***.**:514
        rfc: RFC5424
        facility: local3
        severity: informational
        enrichment: KubernetesMinimal
        appName: "worker-procesador"

  pipelines:
    - name: pipeline-api-procesador
      inputRefs:
        - application-logs
      filterRefs:
        - detect-java-multiline
      outputRefs:
        - syslog-api-procesador

    - name: pipeline-worker-procesador
      inputRefs:
        - application-logs
      filterRefs:
        - detect-java-multiline
      outputRefs:
        - syslog-worker-procesador