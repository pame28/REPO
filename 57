apiVersion: observability.openshift.io/v1
kind: ClusterLogForwarder
metadata:
  name: forward-des-procesadortc-bp-namespace
  namespace: des-procesadortc-bp
spec:
  serviceAccount:
    name: logcollector

  # Filtro: detecta excepciones multilínea Java
  filters:
    - name: detect-java-multiline
      type: detectMultilineException

  # Inputs: solo logs de este namespace
  inputs:
    - name: application-logs
      type: application
      application:
        includes:
          - namespace: des-procesadortc-bp

  # Output: servidor syslog
  outputs:
    - name: syslog-des-procesadortc-bp
      type: syslog
      syslog:
        url: udp://10.100.***.**:514
        rfc: RFC5424
        facility: local3
        severity: informational
        enrichment: KubernetesFull
        appName: '{.kubernetes.labels.app}'  
        msgID: '{.kubernetes.pod_name}'

  # Pipeline: conecta input + filtro + output
  pipelines:
    - name: pipeline-application-logs
      inputRefs:
        - application-logs
      filterRefs:
        - detect-java-multiline
      outputRefs:
        - syslog-des-procesadortc-bp